<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>AROMA SUNÉ · 睡眠与更年期健康评估</title>
  <style>
    * { box-sizing: border-box; font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif; }
    body { background: #f5efe7; margin: 0; padding: 20px; color: #2c2a29; }
    .container { max-width: 800px; margin: 0 auto; background: white; border-radius: 32px; padding: 24px 20px 40px; box-shadow: 0 8px 20px rgba(0,0,0,0.05); }
    .lang-bar { display: flex; justify-content: flex-end; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
    .lang-btn { background: none; border: 1px solid #d4c5b0; padding: 6px 12px; border-radius: 40px; cursor: pointer; transition: 0.2s; }
    .lang-btn.active { background: #b99470; border-color: #b99470; color: white; }
    h1 { font-size: 1.8rem; font-weight: 500; margin: 0 0 8px; color: #5e2e1c; }
    .sub { color: #7e6a5c; border-left: 3px solid #b99470; padding-left: 12px; margin: 12px 0 24px; }
    .question { margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid #eee6dc; }
    select, input[type="number"], input[type="time"], input[type="tel"] { padding: 8px 12px; border-radius: 24px; border: 1px solid #ddd0c0; background: #fffaf5; width: 100%; max-width: 280px; }
    button { background: #b99470; border: none; padding: 12px 24px; border-radius: 40px; font-weight: 600; color: white; cursor: pointer; transition: opacity 0.2s; }
    button:disabled { opacity: 0.6; cursor: not-allowed; }
    .consent-box { background: #f9f3ec; padding: 12px; border-radius: 16px; margin: 20px 0; }
    .report { background-color: #f8f8f4; padding: 1.5rem; border-radius: 24px; margin-top: 2rem; border-left: 4px solid #b99470; }
    .hide { display: none; }
    .toast { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); background: #333; color: white; padding: 10px 20px; border-radius: 40px; font-size: 14px; z-index: 1000; opacity: 0; transition: opacity 0.3s; pointer-events: none; }
    .toast.show { opacity: 1; }
  </style>
</head>
<body>
<div class="container">
  <div class="lang-bar" id="langBar"></div>

  <div id="formSection">
    <h1 id="title">🌙 睡眠与更年期健康评估</h1>
    <div class="sub" id="subtitle">PSQI · 非医疗诊断，仅供自我节奏观察</div>

    <!-- 年龄 + 绝经状态 -->
    <div class="question"><div id="q_age_label">年龄</div><input type="number" id="age" placeholder="e.g., 52"></div>
    <div class="question"><div id="q_meno_label">绝经状态</div><select id="meno"><option value="pre">未绝经</option><option value="peri">围绝经期</option><option value="post">已绝经</option></select></div>

    <!-- PSQI 核心 9 题（中英双语通过 lang 动态切换） -->
    <div class="question"><div id="q1_label">1. 过去一个月，通常几点上床睡觉？</div><input type="time" id="q1"></div>
    <div class="question"><div id="q2_label">2. 过去一个月，通常上床后多久能睡着？</div><select id="q2"><option value="">请选择</option><option value="0">≤15分钟</option><option value="1">16–30分钟</option><option value="2">31–60分钟</option><option value="3">>60分钟</option></select></div>
    <div class="question"><div id="q3_label">3. 过去一个月，通常早上几点起床？</div><input type="time" id="q3"></div>
    <div class="question"><div id="q4_label">4. 过去一个月，每晚实际睡眠多少小时？</div><select id="q4"><option value="">请选择</option><option value="0">>7小时</option><option value="1">6–7小时</option><option value="2">5–6小时</option><option value="3"><5小时</option></select></div>
    <div class="question"><div id="q5_label">5. 过去一个月，整体睡眠质量如何？</div><select id="q5"><option value="">请选择</option><option value="0">非常好</option><option value="1">较好</option><option value="2">较差</option><option value="3">很差</option></select></div>
    <div class="question"><div id="q6_label">6. 过去一个月，使用助眠药物的频率？</div><select id="q6"><option value="">请选择</option><option value="0">从不</option><option value="1">每周<1次</option><option value="2">每周1-2次</option><option value="3">每周≥3次</option></select></div>
    <div class="question"><div id="q7_label">7. 过去一个月，开车/吃饭/社交时难以保持清醒的频率？</div><select id="q7"><option value="">请选择</option><option value="0">从不</option><option value="1">每周<1次</option><option value="2">每周1-2次</option><option value="3">每周≥3次</option></select></div>
    <div class="question"><div id="q8_label">8. 过去一个月，要努力打起精神完成事情的困难程度？</div><select id="q8"><option value="">请选择</option><option value="0">没有</option><option value="1">有一点</option><option value="2">较困难</option><option value="3">很困难</option></select></div>
    <div class="question"><div id="q9_label">9. 过去一个月，伴侣/家人是否注意到你有睡眠问题？</div><select id="q9"><option value="">请选择</option><option value="0">未注意</option><option value="1">轻微</option><option value="2">有些</option><option value="3">很明显</option></select></div>

    <!-- 手机号 + 同意 -->
    <div class="question"><div id="phone_label">📱 手机号（可选，用于接收报告）</div><input type="tel" id="phone" placeholder="+65 8123 4567"></div>
    <div class="consent-box"><label><input type="checkbox" id="consent"> <span id="consent_label">我同意将数据用于睡眠连续性记录与匿名分析，可随时退出</span></label></div>

    <button id="submitBtn">🌱 查看报告</button>
  </div>

  <div id="reportSection" class="report hide">
    <h3>🌙 你的睡眠节奏报告</h3>
    <div id="reportContent"></div>
    <button onclick="resetForm()" style="margin-top:1rem;">回到问卷</button>
  </div>
</div>
<div id="toast" class="toast"></div>

<script>
  const BACKEND = "https://script.google.com/macros/s/AKfycbxB3gLuRfr-vU3yE6yg2qoYQmbNqUmkqnbMhRbh9biWt24vMQKPLhXyVJtJ0lHRS7x1/exec"; // 替换为你的 Apps Script URL

  let currentLang = 'zh';

  const translations = {
    zh: {
      title: "🌙 睡眠与更年期健康评估", subtitle: "PSQI · 非医疗诊断，仅供自我节奏观察",
      age: "年龄", meno: "绝经状态", pre: "未绝经", peri: "围绝经期", post: "已绝经",
      q1: "1. 过去一个月，通常几点上床睡觉？", q2: "2. 过去一个月，通常上床后多久能睡着？", q3: "3. 过去一个月，通常早上几点起床？", q4: "4. 过去一个月，每晚实际睡眠多少小时？", q5: "5. 过去一个月，整体睡眠质量如何？", q6: "6. 过去一个月，使用助眠药物的频率？", q7: "7. 过去一个月，开车/吃饭/社交时难以保持清醒的频率？", q8: "8. 过去一个月，要努力打起精神完成事情的困难程度？", q9: "9. 过去一个月，伴侣/家人是否注意到你有睡眠问题？",
      phone: "📱 手机号（可选，用于接收报告）", consent: "我同意将数据用于睡眠连续性记录与匿名分析，可随时退出",
      btn: "🌱 查看报告", back: "回到问卷"
    },
    en: {
      title: "🌙 Sleep & Menopause Health Assessment", subtitle: "PSQI · quiet self-reflection, not a diagnosis",
      age: "Age", meno: "Menopause status", pre: "Pre", peri: "Peri", post: "Post",
      q1: "1. Bedtime (past month)", q2: "2. Minutes to fall asleep", q3: "3. Wake-up time", q4: "4. Actual sleep hours/night", q5: "5. Overall sleep quality", q6: "6. Sleep medication frequency", q7: "7. Trouble staying awake", q8: "8. Enthusiasm to get things done", q9: "9. Sleep problem noticed by others",
      phone: "📱 Phone (optional, to receive report)", consent: "I consent to sleep tracking, can opt out anytime",
      btn: "🌱 View report", back: "Back to survey"
    }
  };
  translations['ms'] = translations['en'];
  translations['id'] = translations['en'];

  function t(key) { return translations[currentLang]?.[key] || translations.zh[key] || key; }

  function showToast(msg, isErr = false) {
    const toast = document.getElementById('toast');
    toast.textContent = msg;
    toast.style.background = isErr ? '#b91c1c' : '#2c2a29';
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3000);
  }

  function calculatePSQI() {
    let total = 0;
    total += parseInt(document.getElementById('q2').value) || 0;
    total += parseInt(document.getElementById('q4').value) || 0;
    total += parseInt(document.getElementById('q5').value) || 0;
    total += parseInt(document.getElementById('q6').value) || 0;
    total += parseInt(document.getElementById('q7').value) || 0;
    total += parseInt(document.getElementById('q8').value) || 0;
    total += parseInt(document.getElementById('q9').value) || 0;
    return total;
  }

  function getInterpretation(score) {
    if (score <= 5) return '睡眠节奏整体平稳。';
    if (score <= 10) return '有一些波动，温柔关注即可。';
    if (score <= 15) return '睡眠可能承载了较多压力。';
    return '请对自己格外温柔。';
  }

  async function submitToAirtable(data) {
    try {
      await fetch(BACKEND, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
    } catch (err) { console.warn('Airtable log failed', err); }
  }

  function showReport(score, phone, age, meno) {
    const interpretation = getInterpretation(score);
    const reportHtml = `
      <p>感谢你轻轻分享你的睡眠节奏。</p>
      <p><strong>你的 PSQI 总分：${score} / 21</strong></p>
      <p>▸ 0–5：睡眠节奏整体平稳<br>▸ 6–10：有一些波动，温柔关注即可<br>▸ 11–15：睡眠可能承载了较多压力<br>▸ 16–21：请对自己格外温柔</p>
      <p>${interpretation}</p>
      <p>这不是诊断。只是帮助你留意自己的节奏。</p>
      <p>附上一份 gentle 睡眠指南：<br><a href="https://docs.google.com/document/d/你的指南ID/edit" target="_blank">🌙 睡眠指南 PDF</a></p>
      <p>如果你想在 2 周后再次轻轻记录，随时告诉我。不需要有压力。</p>
      ${phone ? `<p>📱 报告已同时发送至 ${phone}（如果你填了手机号）。</p>` : ''}
      <p>🌱 任何时候想退出，回复“not now”即可。</p>
      <hr><footer style="font-size:0.7rem;">quietly part of WTA wellness ecosystem · connected to WSS · WITT AP</footer>
    `;
    document.getElementById('reportContent').innerHTML = reportHtml;
    document.getElementById('formSection').classList.add('hide');
    document.getElementById('reportSection').classList.remove('hide');
  }

  async function onSubmit() {
    if (!document.getElementById('consent').checked) return showToast('需要同意隐私条款', true);
    const phone = document.getElementById('phone').value.trim();
    const age = document.getElementById('age').value;
    const meno = document.getElementById('meno').value;
    const q1 = document.getElementById('q1').value;
    const q2 = document.getElementById('q2').value;
    const q3 = document.getElementById('q3').value;
    const q4 = document.getElementById('q4').value;
    const q5 = document.getElementById('q5').value;
    const q6 = document.getElementById('q6').value;
    const q7 = document.getElementById('q7').value;
    const q8 = document.getElementById('q8').value;
    const q9 = document.getElementById('q9').value;

    const score = calculatePSQI();
    const payload = { phone, age, meno, q1, q2, q3, q4, q5, q6, q7, q8, q9, psqi_total: score, timestamp: new Date().toISOString() };
    await submitToAirtable(payload);
    showReport(score, phone, age, meno);
  }

  function resetForm() {
    document.getElementById('formSection').classList.remove('hide');
    document.getElementById('reportSection').classList.add('hide');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function applyLanguage() {
    document.getElementById('title').innerText = t('title');
    document.getElementById('subtitle').innerText = t('subtitle');
    document.getElementById('q_age_label').innerText = t('age');
    document.getElementById('q_meno_label').innerText = t('meno');
    document.getElementById('q1_label').innerText = t('q1');
    document.getElementById('q2_label').innerText = t('q2');
    document.getElementById('q3_label').innerText = t('q3');
    document.getElementById('q4_label').innerText = t('q4');
    document.getElementById('q5_label').innerText = t('q5');
    document.getElementById('q6_label').innerText = t('q6');
    document.getElementById('q7_label').innerText = t('q7');
    document.getElementById('q8_label').innerText = t('q8');
    document.getElementById('q9_label').innerText = t('q9');
    document.getElementById('phone_label').innerHTML = t('phone');
    document.getElementById('consent_label').innerText = t('consent');
    document.getElementById('submitBtn').innerText = t('btn');
    // 绝经状态选项（固定简单版，未做多语言下拉重填，保持原值）
    const menoSelect = document.getElementById('meno');
    if (menoSelect && menoSelect.options.length === 3) {
      menoSelect.options[0].text = t('pre');
      menoSelect.options[1].text = t('peri');
      menoSelect.options[2].text = t('post');
    }
  }

  function setLanguage(lang) {
    currentLang = lang;
    applyLanguage();
    document.querySelectorAll('.lang-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.lang === lang));
  }

  function renderLangBar() {
    const langs = [{ code: 'zh', name: '中文' }, { code: 'en', name: 'English' }, { code: 'ms', name: 'Melayu' }, { code: 'id', name: 'Indonesia' }];
    const bar = document.getElementById('langBar');
    bar.innerHTML = langs.map(l => `<button class="lang-btn ${currentLang === l.code ? 'active' : ''}" data-lang="${l.code}" onclick="setLanguage('${l.code}')">${l.name}</button>`).join('');
  }

  window.onload = () => {
    renderLangBar();
    applyLanguage();
    document.getElementById('submitBtn').onclick = onSubmit;
    window.resetForm = resetForm;
  };
</script>
</body>
</html>
